{
  "name": "company-dossier",
  "displayName": "Company Dossier — Intelligence Research",
  "description": "Company research & competitive intelligence in VS Code. Enter a company URL and get a structured, multi-section dossier — website crawl, Wayback history, DNS/email recon, tech-stack detection, public records, and AI synthesis (SWOT, executive brief). OSINT for due diligence, sales intelligence, prospect & lead research.",
  "version": "1.2.0",
  "publisher": "EVERJUSTs",
  "author": {
    "name": "EverJust",
    "url": "https://companydossier.lol"
  },
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/ever-just/company-dossier-vscode"
  },
  "homepage": "https://companydossier.lol",
  "bugs": {
    "url": "https://github.com/ever-just/company-dossier-vscode/issues"
  },
  "galleryBanner": {
    "color": "#0d1117",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Data Science",
    "Machine Learning",
    "Other"
  ],
  "keywords": [
    "company research",
    "competitive intelligence",
    "osint",
    "due diligence",
    "business intelligence",
    "company data",
    "sales intelligence",
    "dossier",
    "wayback",
    "dns",
    "tech stack",
    "prospect research",
    "lead research"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "companyDossier",
          "title": "Company Dossier",
          "icon": "icon.png"
        }
      ]
    },
    "views": {
      "companyDossier": [
        {
          "type": "webview",
          "id": "companyDossier.sidebar",
          "name": "Research"
        }
      ]
    },
    "chatParticipants": [
      {
        "id": "company-dossier.agent",
        "name": "dossier",
        "fullName": "Company Dossier Agent",
        "description": "Build competitive intelligence dossiers on any company",
        "isSticky": true,
        "commands": [
          {
            "name": "research",
            "description": "Research a company: /research Company Name https://company.com"
          }
        ]
      }
    ],
    "configuration": {
      "title": "Company Dossier",
      "properties": {
        "companyDossier.anthropicApiKey": {
          "type": "string",
          "default": "",
          "description": "Anthropic API key for AI-powered analysis (console.anthropic.com). Without this, data is collected but LLM synthesis is skipped.",
          "order": 1
        },
        "companyDossier.maxPages": {
          "type": "number",
          "default": 50,
          "description": "Maximum pages to crawl from the target website's sitemap.",
          "order": 2
        }
      }
    },
    "commands": [
      {
        "command": "companyDossier.research",
        "title": "Dossier: Research Company",
        "icon": "$(search)"
      },
      {
        "command": "companyDossier.newEntity",
        "title": "Dossier: New Entity Profile"
      }
    ],
    "snippets": [
      {
        "language": "markdown",
        "path": "./snippets/frontmatter.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.93.0",
    "@vscode/vsce": "^3.0.0",
    "typescript": "^5.3.0"
  },
  "pricing": "Free",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1"
  }
}
